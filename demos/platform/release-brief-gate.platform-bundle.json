{
  "schema_version": 1,
  "bundle_type": "platform",
  "bundle_id": "release-brief-gate",
  "name": "演示包 · 发布简报门禁（多 Agent）",
  "description": "需求澄清/发布写手 Agent、简报验收 Prompt Skill、MCP 模板配置，配合审批与 Checkpoint。",
  "ui_hints": {
    "tags": ["demo", "release", "multi-agent"],
    "estimated_minutes": 6,
    "scene": "发布简报与审批门禁",
    "playbook_url": "/tutorials/demo-playbook-01-release-brief.md"
  },
  "builtin_skill_catalog": [],
  "skills": [
    {
      "bundle_key": "skill_brief_checker",
      "skill_id": "demo.bundle.brief_checker",
      "name": "Demo · 简报字段检查",
      "description": "检查发布简报草稿是否具备 text 与 summary 字段（Prompt Skill）。",
      "category": "demo",
      "type": "prompt",
      "definition": {
        "prompt_template": "检查下列草稿是否同时包含清晰的正文 text 与一句话 summary；若缺失则指出缺项，否则回复 OK。\n\n{{text}}"
      },
      "input_schema": {
        "type": "object",
        "properties": {
          "text": { "type": "string" }
        },
        "required": ["text"]
      }
    }
  ],
  "mcp_servers": [
    {
      "bundle_key": "mcp_fs_template",
      "name": "Demo · MCP 文件系统（模板）",
      "description": "默认关闭；启用后可在 Settings→MCP Probe 并将工具 Import 为平台 Skill。",
      "transport": "stdio",
      "command": ["npx", "-y", "@modelcontextprotocol/server-filesystem", "/tmp"],
      "enabled": false,
      "optional": true
    }
  ],
  "mcp_tool_imports": [
    {
      "server_bundle_key": "mcp_fs_template",
      "optional": true,
      "skip_if_disabled": true
    }
  ],
  "agents": [
    {
      "bundle_key": "agent_clarifier",
      "name": "Demo · 需求澄清员",
      "description": "分析简报并列出目标、约束与待确认项。",
      "model_id": "__AUTO_LLM__",
      "enabled_skills": [],
      "system_prompt": "你是需求澄清专家。根据用户简报输出结构化澄清：目标、受众、约束、非目标、待确认问题。输出 Markdown。",
      "max_steps": 8,
      "temperature": 0.4
    },
    {
      "bundle_key": "agent_writer",
      "name": "Demo · 发布写手",
      "description": "按计划撰写发布简报，输出含 text 与 summary 的 JSON。",
      "model_id": "__AUTO_LLM__",
      "enabled_skills": ["$import:skill_brief_checker"],
      "system_prompt": "你是技术产品发布写手。根据上游计划撰写发布简报，必须输出 JSON：{\"text\": \"正文\", \"summary\": \"一句话摘要\"}。可先调用简报字段检查技能自检。",
      "max_steps": 12,
      "temperature": 0.3
    }
  ],
  "workflows": [
    {
      "bundle_key": "wf_release_brief",
      "workflow_name": "Demo · 发布简报门禁（多 Agent）",
      "description": "澄清 Agent → 计划模板 → 审批 → 写手 Agent → Checkpoint",
      "tags": ["demo", "platform-bundle", "multi-agent", "approval", "checkpoint"],
      "sample_input": {
        "brief": "下月 v1.2 发布公告，面向开发者，强调工作流编排与多 Agent 控制能力。"
      },
      "dag": {
        "entry_node": "start",
        "global_config": {
          "bundle_id": "release-brief-gate"
        },
        "nodes": [
          {
            "id": "start",
            "type": "input",
            "name": "Start",
            "config": { "workflow_node_type": "start" },
            "position": { "x": 80, "y": 200 }
          },
          {
            "id": "input_brief",
            "type": "input",
            "name": "Brief",
            "config": {
              "workflow_node_type": "input",
              "input_key": "brief",
              "input_schema": {
                "type": "object",
                "properties": { "brief": { "type": "string" } },
                "required": ["brief"]
              }
            },
            "position": { "x": 240, "y": 200 }
          },
          {
            "id": "clarify",
            "type": "agent",
            "name": "需求澄清",
            "config": {
              "workflow_node_type": "agent",
              "agent_id": "$import:agent_clarifier",
              "agent_display_name": "Demo · 需求澄清员"
            },
            "position": { "x": 440, "y": 200 }
          },
          {
            "id": "plan",
            "type": "prompt_template",
            "name": "Plan Template",
            "config": {
              "workflow_node_type": "prompt_template",
              "role": "user",
              "template": "根据澄清结果输出分步实施计划（含验收标准），Markdown 即可：\n\n{{prev.text}}"
            },
            "position": { "x": 640, "y": 200 }
          },
          {
            "id": "approval_plan",
            "type": "tool",
            "name": "Plan Approval",
            "config": {
              "workflow_node_type": "approval",
              "title": "确认实施计划",
              "description": "请审核计划后再继续执行；驳回将阻断下游。"
            },
            "position": { "x": 840, "y": 200 }
          },
          {
            "id": "execute",
            "type": "agent",
            "name": "发布撰写",
            "config": {
              "workflow_node_type": "agent",
              "agent_id": "$import:agent_writer",
              "agent_display_name": "Demo · 发布写手"
            },
            "position": { "x": 1040, "y": 200 }
          },
          {
            "id": "checkpoint_verify",
            "type": "tool",
            "name": "Verify",
            "config": {
              "workflow_node_type": "checkpoint",
              "description": "执行结果须含 text、summary，且上游无 error",
              "required_keys": ["text", "summary"],
              "forbid_error_key": true
            },
            "position": { "x": 1240, "y": 200 }
          },
          {
            "id": "output_deliverable",
            "type": "output",
            "name": "Deliverable",
            "config": {
              "workflow_node_type": "output",
              "output_key": "deliverable"
            },
            "position": { "x": 1440, "y": 200 }
          }
        ],
        "edges": [
          { "from_node": "start", "to_node": "input_brief" },
          { "from_node": "input_brief", "to_node": "clarify" },
          { "from_node": "clarify", "to_node": "plan" },
          { "from_node": "plan", "to_node": "approval_plan" },
          { "from_node": "approval_plan", "to_node": "execute" },
          { "from_node": "execute", "to_node": "checkpoint_verify" },
          { "from_node": "checkpoint_verify", "to_node": "output_deliverable" }
        ]
      }
    }
  ]
}
